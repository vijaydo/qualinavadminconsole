{
  "version": 1,
  "name": "Improvement Charter",
  "slug": "improvement-charter",
  "description": "The default 4-canvas QI project journey: Improvement Canvas, Matrix Diagram, Gameplan Canvas, Commit. Based on the dotank Improvement Canvas + Heartland Intellicare workflow.",
  "tabs": [
    {
      "key": "improvement_canvas",
      "label": "1. Improvement Canvas",
      "title": "The Improvement Canvas",
      "description": "This canvas is the most comprehensive of all the improvement canvases within the suite of implementation materials, and is also the most critical. This is where you are mapping out the specifics around what your team is trying to accomplish, how you will measure your progress, and what tangible action steps you will take to achieve your aim. Follow the steps below to use this canvas to map out your improvement journey.",
      "image": "assets/canvas/improvement-canvas.webp",
      "canvas_overlays": [
        { "n": 9, "zone_key": "team",         "label": "Team Members",             "source": "improvement_canvas.team_members",  "position": "12.4%,2.9%,18.1%,34.4%" },
        { "n": 1, "zone_key": "done_before",  "label": "What have we done before?","source": "improvement_canvas.previous_work", "position": "12.4%,23.4%,53.7%,16.8%" },
        { "n": 2, "zone_key": "scope_in",     "label": "In Scope",                 "source": "improvement_canvas.scope", "source_slot": "in_scope",     "position": "16.5%,79.6%,18.1%,14.6%" },
        { "n": 2, "zone_key": "scope_out",    "label": "Out of Scope",             "source": "improvement_canvas.scope", "source_slot": "out_of_scope", "position": "32.9%,79.6%,18.1%,13.9%" },
        { "n": 3, "zone_key": "population",   "label": "Population",               "source": "improvement_canvas.accomplish", "source_slot": "population", "position": "33%,26%,9.5%,12.5%" },
        { "n": 3, "zone_key": "goal",         "label": "Goal",                     "source": "improvement_canvas.accomplish", "source_slot": "goal",       "position": "33%,36.5%,9.5%,12.5%" },
        { "n": 3, "zone_key": "time",         "label": "Time Expectation",         "source": "improvement_canvas.accomplish", "source_slot": "time",       "position": "33%,47%,9.5%,12.5%" },
        { "n": 3, "zone_key": "location",     "label": "Location",                 "source": "improvement_canvas.accomplish", "source_slot": "location",   "position": "33%,57.5%,9.5%,12.5%" },
        { "n": 3, "zone_key": "guidance",     "label": "Guidance",                 "source": "improvement_canvas.accomplish", "source_slot": "guidance",   "position": "33%,68%,9.5%,12.5%" },
        { "n": 5, "zone_key": "outcome",      "label": "Outcome Measure",          "source": "improvement_canvas.measures", "source_slot": "outcome",       "position": "49.8%,36.5%,9.5%,10.2%" },
        { "n": 5, "zone_key": "process",      "label": "Process Measure",          "source": "improvement_canvas.measures", "source_slot": "process",       "position": "49.8%,47%,9.5%,10.2%" },
        { "n": 5, "zone_key": "tracking",     "label": "Tracking Tool",            "source": "improvement_canvas.measures", "source_slot": "tracking_tool", "position": "49.8%,57.5%,9.5%,10.2%" },
        { "n": 6, "zone_key": "idea_1",       "label": "Idea 1",                   "source": "improvement_canvas.change_ideas", "source_slot": "idea_1", "position": "67%,26%,9.5%,10.2%" },
        { "n": 6, "zone_key": "idea_2",       "label": "Idea 2",                   "source": "improvement_canvas.change_ideas", "source_slot": "idea_2", "position": "67%,36.5%,9.5%,10.2%" },
        { "n": 6, "zone_key": "idea_3",       "label": "Idea 3",                   "source": "improvement_canvas.change_ideas", "source_slot": "idea_3", "position": "67%,47%,9.5%,10.2%" },
        { "n": 6, "zone_key": "idea_4",       "label": "Idea 4",                   "source": "improvement_canvas.change_ideas", "source_slot": "idea_4", "position": "67%,57.5%,9.5%,10.2%" },
        { "n": 6, "zone_key": "idea_5",       "label": "Idea 5",                   "source": "improvement_canvas.change_ideas", "source_slot": "idea_5", "position": "67%,68%,9.5%,10.2%" },
        { "n": 7, "zone_key": "supports",     "label": "Supports",                 "source": "improvement_canvas.supports", "position": "50.5%,2.9%,18.1%,42.5%" },
