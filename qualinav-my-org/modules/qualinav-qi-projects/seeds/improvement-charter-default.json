          "helper": "Once your team is satisfied with the information entered above, click \"Mark Complete\" to submit your charter. This will indicate that your QI work is finalized and we will generate your final report.",
          "color": "cream",
          "fields": [
            { "type": "submit_button", "field_path": "commit.mark_complete", "label": "Mark Complete and Generate Report" }
          ]
        }
      ]
    }
  ]
