    {
      "key": "commit",
      "label": "4. Commit",
      "title": "Commit",
      "description": "Finalize your action plan and share it with leadership or other stakeholders. Refine the work you've done in the last three sessions to have an easily shareable concise charter that you can use to secure necessary buy-in to move to action towards your goal.",
      "steps": [
        {
          "key": "commit_aim",
          "title": "What are we trying to accomplish?",
          "color": "blue",
          "fields": [
            {
              "type": "field_reference",
              "field_path": "commit.aim_statement",
              "source": "improvement_canvas.aim_statement",
              "label": "AIM STATEMENT",
              "editable": true
            }
          ]
        },
        {
          "key": "commit_measures",
          "title": "How are we going to measure this?",
          "helper": "Refine your outcome and process measures with current and target values.",
          "color": "blue",
          "fields": [
            { "type": "measure_row", "field_path": "commit.outcome_measures", "measure_type": "outcome", "label": "OUTCOME MEASURES" },
            { "type": "measure_row", "field_path": "commit.process_measures", "measure_type": "process", "label": "PROCESS MEASURES" },
            {
              "type": "field_reference",
              "field_path": "commit.tracking_tools",
              "source": "improvement_canvas.measures",
              "source_slot": "tracking_tool",
              "label": "TRACKING TOOLS"
            }
          ]
        },
        {
          "key": "commit_changes",
          "title": "What changes will we make?",
          "color": "green",
          "fields": [
            {
              "type": "scored_ideas_summary",
              "field_path": "commit.ideas",
              "ideas_source": "improvement_canvas.change_ideas",
              "scores_source": "matrix_diagram.scores",
              "changes_field_path": "commit.changes"
            },
            {
              "type": "field_reference",
              "field_path": "commit.supports_barriers",
              "source": "improvement_canvas.supports_barriers",
              "label": "Supports / Barriers (mirrored)"
            },
            {
              "type": "field_reference",
              "field_path": "commit.scope",
              "source": "improvement_canvas.scope",
              "label": "Scope (mirrored)"
            }
          ]
        },
        {
          "key": "commit_team",
          "title": "Team",
          "color": "green",
          "fields": [
            { "type": "card_list", "field_path": "commit.executive_sponsors", "label": "EXECUTIVE SPONSORS" },
            {
              "type": "field_reference",
              "field_path": "commit.team_members",
              "source": "improvement_canvas.team_members",
              "label": "TEAM MEMBERS"
            }
          ]
        },
        {
          "key": "commit_submit",
