        { "zone_key": "gp_p3_actions",   "label": "Phase 3 Action Steps",         "source": "gameplan.phase_3.action_steps",   "position": "30%,50%,21%,38%" },
        { "zone_key": "gp_p3_support",   "label": "Phase 3 Support Needed",       "source": "gameplan.phase_3.support_needed", "position": "72%,50%,10%,21%" },
