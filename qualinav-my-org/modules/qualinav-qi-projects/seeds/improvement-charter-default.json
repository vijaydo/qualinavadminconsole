      ],
      "steps": [
        {
          "key": "targets",
          "title": "Step 1: Our Targets",
          "helper": "What is the ultimate goal we are aiming for? What are other secondary objectives we might look to accomplish? What other stakeholders (beyond our team members) may we need to bring into the process?",
          "color": "blue",
          "fields": [
            {
              "type": "field_reference",
              "field_path": "gameplan.aim_to_execute",
