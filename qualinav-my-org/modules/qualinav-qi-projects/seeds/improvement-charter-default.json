      ],
      "steps": [
        {
          "key": "previous_work",
          "title": "Step 1: What have we done before?",
          "helper": "What work have we done in this space? What is work we've done that is comparable? What prior work should we look to or be aware of as we hone in on our focus area? (Add as many initiatives or examples as you have!)",
          "color": "blue",
          "fields": [
            { "type": "card_list", "field_path": "improvement_canvas.previous_work" }
          ]
        },
        {
          "key": "scope",
          "title": "Step 2: Scope",
          "helper": "Think of this as an exercise in setting boundaries! Within our focus area-what is in scope of this project and what is out of scope? Out of scope activities or focuses don't mean they're things you'll never do, but could be things you can't do right now.",
          "color": "blue",
          "fields": [
            {
              "type": "card_list_2col",
              "field_path": "improvement_canvas.scope",
              "columns": [
                { "key": "in_scope",     "label": "IN SCOPE" },
                { "key": "out_of_scope", "label": "OUT OF SCOPE" }
              ]
            }
          ]
        },
        {
          "key": "accomplish",
          "title": "Step 3: What are we Trying to Accomplish?",
          "helper": "Your aim statement should be explicit, clear, unambiguous, precise, and plain. An aim statement should include the following essential components: Population (Who are the stakeholders you are aiming to make improvements for?), Goal (What is the goal you are trying to achieve?), Time Expectation (when will this work take place? From when to when?), Location (Where will this work take place? Be specific: site, department, etc.), Guidance (Under the guidance of who?)",
          "color": "green",
          "fields": [
            {
              "type": "card_slots_named",
              "field_path": "improvement_canvas.accomplish",
              "slots": [
                { "key": "population", "label": "POPULATION" },
                { "key": "goal",       "label": "GOAL" },
                { "key": "time",       "label": "TIME" },
                { "key": "location",   "label": "LOCATION" },
                { "key": "guidance",   "label": "GUIDANCE" }
              ]
            }
          ]
        },
        {
          "key": "aim_statement",
          "title": "Step 4: Aim Statement",
          "helper": "Using the components you defined in Step 3, write your aim statement as a clear and concise sentence that you can share to communicate the aim of your work, and to use as a \"North Star\" for your team moving forward.",
          "color": "green",
          "fields": [
            { "type": "single_textarea", "field_path": "improvement_canvas.aim_statement" }
          ]
        },
        {
          "key": "measures",
          "title": "Step 5: How Will We Measure This?",
          "helper": "Strong measurement requires thinking through three key components: Outcome Measure (What you are measuring in your aim statement. The ultimate quantitative number you want to achieve.), Process Measure (The specific steps in the process that lead to your outcome metric.), Tracking Tool (The system you will have in place to monitor and track your Outcome and Process measures.)",
          "color": "yellow",
          "fields": [
            {
              "type": "card_slots_named",
              "field_path": "improvement_canvas.measures",
              "slots": [
                { "key": "outcome",       "label": "OUTCOME" },
                { "key": "process",       "label": "PROCESS" },
                { "key": "tracking_tool", "label": "TRACKING TOOL" }
              ]
            }
          ]
        },
        {
          "key": "change_ideas",
          "title": "Step 6: What Will We Do Differently?",
          "helper": "A change idea is an actionable, specific idea for changing a process. Change ideas come from research, best practices or other organizations that have used the idea (technique) to achieve gains. Write out the actions you think need to take place to achieve your aim statement to help you make progress within your selected focus area and help you reach your ultimate goal.",
          "color": "pink",
          "fields": [
            {
              "type": "card_slots_numbered",
              "field_path": "improvement_canvas.change_ideas",
              "count": 5,
              "slot_label_format": "IDEA {n}"
            }
          ]
        },
        {
          "key": "supports",
          "title": "Step 7: Supports",
          "helper": "What supports do we have going into this work that we can utilize or will help us in this effort?",
          "color": "lavender",
          "fields": [
            { "type": "card_list", "field_path": "improvement_canvas.supports" }
          ]
        },
        {
          "key": "barriers",
          "title": "Step 8: Barriers",
          "helper": "What barriers exist that might make this work challenging that we should be aware of or work to mitigate?",
          "color": "purple",
          "fields": [
            { "type": "card_list", "field_path": "improvement_canvas.barriers" }
          ]
        },
        {
          "key": "team_members",
          "title": "Step 9: Team Members",
          "helper": "Who will be essential members of this team? Think about both specific people and departments/roles.",
          "color": "gray",
          "fields": [
            { "type": "card_list", "field_path": "improvement_canvas.team_members", "picker": "org_users" }
          ]
        }
      ]
    },
    {
      "key": "matrix_diagram",
      "label": "2. Matrix Diagram",
      "title": "The Matrix Diagram",
      "description": "This canvas is the most comprehensive of all the improvement canvases within the suite of implementation materials, and is also the most critical.\n\nThis is where you are mapping out the specifics around what your team is trying to accomplish, how you will measure your progress, and what tangible action steps you will take to achieve your aim. Follow the steps below to use this canvas to map out your improvement journey.",
      "image": "assets/canvas/matrix-diagram.png",
      "canvas_score_grid": {
        "ideas_source":         "improvement_canvas.change_ideas",
        "scores_source":        "matrix_diagram.scores",
        "lock_path":            "matrix_diagram.locked",
        "criteria": [
          { "key": "achievable_in_90_days" },
          { "key": "will_to_support" },
          { "key": "within_control" },
          { "key": "sponsor_buyin" }
        ],
        "row_count":           5,
        "header_top":          21.05,
        "row_height":          14.26,
        "criteria_left":       11.23,
        "criterion_col_width": 17.48,
        "cumulative_left":     81.35,
        "cumulative_width":    17.29
      },
      "fields": [
        {
          "type": "idea_score_matrix",
          "field_path": "matrix_diagram.scores",
          "ideas_source": "improvement_canvas.change_ideas",
          "lock_path": "matrix_diagram.locked",
          "criteria": [
            { "key": "achievable_in_90_days", "label": "The solution can be accomplished in 90 days" },
            { "key": "will_to_support",       "label": "There is the will to support this solution" },
            { "key": "within_control",        "label": "The solution is within our control" },
            { "key": "sponsor_buyin",         "label": "We have a sponsor and buy-in for this solution" }
          ]
        }
      ]
    },
    {
      "key": "gameplan",
      "label": "3. Gameplan Canvas",
      "title": "The Gameplan Canvas",
